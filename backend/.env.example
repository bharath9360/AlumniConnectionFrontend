# ─── Server ───────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?appName=<app>

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Frontend URL (CORS + redirect links in emails) ───────────
FRONTEND_URL=http://localhost:3000

# ─── Admin secret key (required for admin register/login) ─────
ADMIN_SECRET_KEY=

# ─── Cloudinary (image uploads) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email Provider ───────────────────────────────────────────
# Options: "resend" | "nodemailer"
EMAIL_PROVIDER=nodemailer
EMAIL_USER=

# ─── Resend (alternative email provider) ─────────────────────
RESEND_API_KEY=

# ─── Gmail API via OAuth2 (nodemailer provider) ───────────────
# Generate tokens at: https://developers.google.com/oauthplayground
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ─── Load Testing (Artillery) ─────────────────────────────────
LOAD_TEST_EMAIL=
LOAD_TEST_PASSWORD=

# ─── Seed Script (node seed.js) ───────────────────────────────
# Password assigned to all seed users — change before seeding production!
SEED_PASSWORD=
